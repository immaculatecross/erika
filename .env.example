# OpenAI API key with access to the gpt-audio model family (native audio analysis).
OPENAI_API_KEY=

# Azure AI Speech — OPTIONAL (E-37, D-21). The pronunciation studio's core loop (hear
# the correct line, say it back, hear yourself) works WITHOUT these; they only enable
# the extra step of scoring a drill take per word and per sound. Server-only: the key
# must never reach the browser, a log, or a commit. Set the region OR an explicit
# resource/private endpoint (the endpoint wins when both are present).
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
# AZURE_SPEECH_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com

# Pronunciation score → feedback thresholds (E-37). Tunable, with documented defaults
# in lib/pronunciation/thresholds.ts. They are OUR CHOICES, transferred from
# English-language norms: no labelled Italian pronunciation-assessment corpus exists to
# validate them against, so they are never presented as calibrated.
# PRON_GOOD_SCORE=80
# PRON_SHAKY_SCORE=60
# PRON_PASS_SCORE=80
# PRON_MIN_SNR_DB=10
